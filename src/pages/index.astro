---
import Layout from '../layouts/Layout.astro'
import { Icon } from 'astro-icon/components'
---

<Layout>
  <main class="flex flex-1 w-full max-w-[1200px] mx-auto flex-col items-center justify-center gap-8 px-6 py-24 text-center">
    <div class="flex size-16 items-center justify-center rounded-md bg-gray-1000 text-background-100 shadow-card">
      <Icon size={32} name="lucide:sparkles" />
    </div>

    <div class="flex max-w-xl flex-col gap-4">
      <h1 class="heading-40 md:heading-48">Start building with Hazeloft Studio</h1>
      <p class="copy-16 text-gray-900">
        This project uses the Hazeloft design system: a 100–1000 color
        scale, and ready-made component recipes. Edit
        <code class="copy-14-mono rounded-sm bg-gray-100 px-1.5 py-0.5">src/pages/index.astro</code>
        to get started.
      </p>
    </div>

    <div class="flex flex-col gap-4 sm:flex-row">
      <a class="btn-primary w-full sm:w-40" href="https://hazeloft.com" target="_blank" rel="noopener noreferrer">
        Get Started
      </a>
      <a class="btn-secondary w-full sm:w-40" href="https://docs.astro.build" target="_blank" rel="noopener noreferrer">
        Documentation
      </a>
    </div>
  </main>
</Layout>
